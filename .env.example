# App — canonical production URL (must match Supabase Auth redirect allow list).
NEXT_PUBLIC_SITE_URL=https://www.letlogic.app

# Supabase (from Project Settings → API)
# Auth redirect URLs (add all in Supabase → Authentication → URL configuration):
#   https://www.letlogic.app/auth/callback
#   https://letlogic.app/auth/callback
#   http://localhost:3000/auth/callback
# Branded auth email templates (logo header + signature) live in supabase/templates/.
# Run: npm run generate:auth-email-templates
# Run: SUPABASE_ACCESS_TOKEN=... npm run configure:auth-email-templates
# Run: SUPABASE_ACCESS_TOKEN=... RESEND_API_KEY=... npm run configure:supabase-smtp
# SMTP sender defaults to support@letlogic.app (LetLogic).
# Auth rate limits: Supabase → Authentication → Rate Limits (default ~2 emails/hr while testing)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin — comma-separated emails allowed to access /admin
ADMIN_EMAILS=founder@example.com,ops@example.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# AI
OPENAI_API_KEY=

# Email
RESEND_API_KEY=
# Supabase Auth SMTP sender (Resend). Run configure:supabase-smtp after domain verification.
SMTP_ADMIN_EMAIL=support@letlogic.app
SMTP_SENDER_NAME=LetLogic
# Inbound webhook signing secret (Resend → Webhooks, event: email.received)
RESEND_WEBHOOK_SECRET=
# Private inbox for contact form + forwarded @letlogic.app mail
CONTACT_INBOX_EMAIL=scott.maryan@icloud.com

# Cron protection — Authorization: Bearer <CRON_SECRET> on /api/cron/* routes
CRON_SECRET=generate-with-openssl-rand-base64-32

# Legal entity (required before public launch — see npm run verify:production)
NEXT_PUBLIC_COMPANY_LEGAL_NAME=LetLogic Ltd
NEXT_PUBLIC_COMPANY_REGISTERED_IN=England and Wales
NEXT_PUBLIC_COMPANY_NUMBER=
NEXT_PUBLIC_COMPANY_ADDRESS=
NEXT_PUBLIC_LEGAL_UPDATED=17 June 2026
NEXT_PUBLIC_CONTACT_EMAIL=hello@letlogic.app
NEXT_PUBLIC_SUPPORT_EMAIL=support@letlogic.app
NEXT_PUBLIC_PRIVACY_EMAIL=privacy@letlogic.app

# SEO — comma-separated public social/profile URLs for Organization schema `sameAs` (optional)
NEXT_PUBLIC_SOCIAL_URLS=

# Error monitoring (optional locally; required in production)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
