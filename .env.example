# App — canonical production URL (must match Supabase Auth redirect allow list).
NEXT_PUBLIC_SITE_URL=https://www.letlogic.app

# Supabase (from Project Settings → API)
# Auth redirect URLs (add all in Supabase → Authentication → URL configuration):
#   https://www.letlogic.app/auth/callback
#   https://www.letlogic.app/auth/confirm
#   https://letlogic.app/auth/callback
#   https://letlogic.app/auth/confirm
#   http://localhost:3000/auth/callback
# Branded auth email templates (logo header + signature) live in supabase/templates/.
# Run: npm run generate:auth-email-templates
# Run: SUPABASE_ACCESS_TOKEN=... npm run configure:auth-email-templates
# Auth: Turnstile + optional Zoho SMTP via npm run configure:supabase-smtp
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin — comma-separated emails allowed to access /admin
ADMIN_EMAILS=founder@example.com,ops@example.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# AI
OPENAI_API_KEY=

# Bot protection for signup + password reset (Cloudflare Turnstile)
# Test keys (always pass): site 1x00000000000000000000AA secret 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Single public inbox — forward hello@ → scott.maryan@icloud.com (Cloudflare Email Routing or Zoho).
NEXT_PUBLIC_CONTACT_EMAIL=hello@letlogic.app

# Auth email SMTP (Zoho Mail recommended). Use the same hello@ mailbox for sending password-reset mail.
# Confirm host in Zoho → Settings → Mail Accounts → Server details (region + smtp vs smtppro).
# Use an app-specific password if 2FA is on.
# Then: npm run configure:supabase-smtp && npm run verify:auth-config
SMTP_HOST=smtp.zoho.eu
SMTP_PORT=587
SMTP_USER=hello@letlogic.app
SMTP_PASS=
SMTP_ADMIN_EMAIL=hello@letlogic.app
SMTP_SENDER_NAME=LetLogic
# Optional caps (only applied when SMTP is configured):
# AUTH_EMAIL_RATE_LIMIT=10
# AUTH_EMAIL_MIN_INTERVAL_SECONDS=60

# Outbound transactional email (Amazon SES) — intake notifications, etc.
# Auth emails still go via Supabase SMTP (Zoho). Use eu-west-1 (Ireland) or eu-central-1 (Frankfurt).
# Verify letlogic.app (or hello@letlogic.app) in SES → Verified identities before sending.
# IAM user needs ses:SendEmail on the verified identity. In SES sandbox, verify recipient emails too.
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=hello@letlogic.app
SES_FROM_NAME=LetLogic
# Recipient for npm run verify:ses (or pass as CLI arg)
SES_TEST_TO=

# Legal identity (sole trader by default — no company number or public address)
# entity type: sole_trader | limited_company
NEXT_PUBLIC_COMPANY_LEGAL_NAME=LetLogic
NEXT_PUBLIC_COMPANY_ENTITY_TYPE=sole_trader
NEXT_PUBLIC_COMPANY_REGISTERED_IN=England and Wales
NEXT_PUBLIC_LEGAL_UPDATED=8 July 2026

# SEO — comma-separated public social/profile URLs for Organization schema `sameAs` (optional)
NEXT_PUBLIC_SOCIAL_URLS=
# Bing Webmaster Tools HTML tag verification (optional — add after registering at bing.com/webmasters)
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Error monitoring (optional locally; required in production)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Source map upload at build time (Vercel Production + Preview)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
