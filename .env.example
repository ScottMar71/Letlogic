# App — canonical production URL (must match Supabase Auth redirect allow list).
NEXT_PUBLIC_SITE_URL=https://www.letlogic.app

# Supabase (from Project Settings → API)
# Auth redirect URLs (add all in Supabase → Authentication → URL configuration):
#   https://www.letlogic.app/auth/callback
#   https://letlogic.app/auth/callback
#   http://localhost:3000/auth/callback
# Auth rate limits: Supabase → Authentication → Rate Limits (default ~2 emails/hr while testing)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# AI
OPENAI_API_KEY=

# Email
RESEND_API_KEY=

# Cron protection — Authorization: Bearer <CRON_SECRET> on /api/cron/* routes
CRON_SECRET=generate-with-openssl-rand-base64-32
